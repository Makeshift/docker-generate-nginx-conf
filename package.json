{
  "name": "docker-generate-nginx-conf",
  "version": "0.1.0",
  "description": "Generates nginx conf from events on the docker socket",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "target:dev": "bun build --target=bun --outdir=dist --sourcemap=linked index.ts",
    "copy-templates": "cp -r templates dist/templates",
    "build": "bun run --sequential clean target:dev copy-templates",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "Connor Bell (Makeshift@Github)",
  "license": "ISC",
  "dependencies": {
    "dockerode": "^5.0.0",
    "es6-template-strings": "^2.0.1"
  },
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  },
  "devDependencies": {
    "@makeshift27015/eslint-config": "^2.1.5",
    "@types/bun": "^1.3.14",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.0.0"
  }
}
